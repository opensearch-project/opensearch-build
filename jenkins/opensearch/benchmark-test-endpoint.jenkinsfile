lib = library(identifier: 'jenkins@aoss-v2', retriever: modernSCM([

    $class: 'GitSCMSource',
    remote: 'https://github.com/rishabh6788/opensearch-build-libraries.git',
]))

pipeline {
    agent none
    options {
        timeout(time: 24, unit: 'HOURS')
        buildDiscarder(logRotator(daysToKeepStr: '30'))
    }
    environment {
        AGENT_LABEL = 'Jenkins-Agent-AL2023-X64-M52xlarge-Benchmark-Test'
        JOB_NAME = 'benchmark-test'
    }
    triggers {
            parameterizedCron(
